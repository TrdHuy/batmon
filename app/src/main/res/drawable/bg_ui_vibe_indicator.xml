<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="0"
                android:centerColor="#12B4FF"
                android:endColor="#64E4FF"
                android:startColor="#E951D6"
                android:type="sweep" />
        </shape>
    </item>

    <item
        android:bottom="3dp"
        android:left="3dp"
        android:right="3dp"
        android:top="3dp">
        <shape android:shape="oval">
            <solid android:color="#1B2733" />
        </shape>
    </item>
</layer-list>
