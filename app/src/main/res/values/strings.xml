    <string name="feature_guide_background_monitoring_title">Background Monitoring</string>
    <string name="feature_guide_background_monitoring_short_description">Theo dõi pin tay cầm ở background.</string>
    <string name="feature_guide_background_monitoring_what_it_does">Background Monitoring giữ một notification đang chạy để cập nhật tình trạng pin tay cầm PS4 ngay cả khi bạn không mở màn hình chính của app.</string>
    <string name="feature_guide_background_monitoring_benefits">- Dễ theo dõi pin trong lúc chơi game.\n- Không cần quay lại app liên tục.\n- Giảm rủi ro tay cầm hết pin bất ngờ.</string>
    <string name="feature_guide_background_monitoring_how_it_works">Khi bật, GLIMPSE chạy foreground service để đọc trạng thái tay cầm định kỳ và hiển thị thông tin qua notification.</string>
    <string name="feature_guide_background_monitoring_notes">Cần quyền notification để hiển thị trạng thái. Trên một số phiên bản Android, app cũng cần quyền Bluetooth để đọc tay cầm.</string>
    <string name="feature_guide_live_battery_overlay_title">Live Battery Overlay</string>
    <string name="feature_guide_live_battery_overlay_short_description">Hiển thị pin tay cầm bằng floating overlay.</string>
    <string name="feature_guide_live_battery_overlay_what_it_does">Live Battery Overlay đặt một chỉ báo pin nhỏ lên trên màn hình để bạn xem nhanh pin tay cầm trong khi đang chơi.</string>
    <string name="feature_guide_live_battery_overlay_benefits">- Xem pin mà không rời khỏi game.\n- Phù hợp khi chơi full screen.\n- Có thể bật/tắt nhanh từ GLIMPSE.</string>
    <string name="feature_guide_live_battery_overlay_how_it_works">GLIMPSE dùng quyền overlay của hệ thống để vẽ một cửa sổ nhỏ phía trên app khác và cập nhật pin từ controller đang kết nối.</string>
    <string name="feature_guide_live_battery_overlay_notes">Cần cấp quyền overlay trong cài đặt hệ thống trước khi hiển thị floating overlay.</string>
    <string name="feature_guide_customize_vibe_title">Customize Vibe</string>
    <string name="feature_guide_customize_vibe_short_description">Test và tùy chỉnh màu light bar của tay cầm.</string>
    <string name="feature_guide_customize_vibe_what_it_does">Customize Vibe cho phép thử nhanh màu light bar trên tay cầm PS4 đang kết nối.</string>
    <string name="feature_guide_customize_vibe_benefits">- Nhận diện tay cầm dễ hơn.\n- Cá nhân hóa trải nghiệm chơi game.\n- Kiểm tra nhanh controller có hỗ trợ đổi màu hay không.</string>
    <string name="feature_guide_customize_vibe_how_it_works">Khi bạn chọn màu, GLIMPSE gửi lệnh đổi light bar đến tay cầm đang active.</string>
    <string name="feature_guide_customize_vibe_notes">Cần có tay cầm tương thích đang kết nối. Một số thiết bị hoặc phiên bản Android có thể không cho phép điều khiển light bar.</string>
    <string name="feature_guide_protect_battery_title">Protect Battery</string>
    <string name="feature_guide_protect_battery_short_description">Cảnh báo khi pin tay cầm đang sạc đạt 80%%.</string>
    <string name="feature_guide_protect_battery_what_it_does">Protect Battery theo dõi pin tay cầm khi đang sạc và gửi cảnh báo khi tay cầm đạt 80%% để bạn rút sạc thủ công.</string>
    <string name="feature_guide_protect_battery_benefits">- Giúp tránh sạc tay cầm quá lâu.\n- Phù hợp khi không có cơ chế tự ngắt sạc.\n- Giữ thói quen sạc pin lành mạnh hơn.</string>
    <string name="feature_guide_protect_battery_how_it_works">Khi bật, GLIMPSE kiểm tra tay cầm định kỳ. Nếu pin tay cầm đang sạc đạt ngưỡng 80%%, app gửi notification cảnh báo.</string>
    <string name="feature_guide_protect_battery_notes">Đây là cảnh báo cho pin tay cầm, không phải pin điện thoại. Cần quyền notification để nhận cảnh báo.</string>
