    <string name="feature_guide_title">Feature Guide</string>
    <string name="feature_guide_intro">Tìm hiểu các tính năng chính của GLIMPSE và khi nào nên sử dụng chúng.</string>
    <string name="feature_guide_section_what_it_does">What it does</string>
