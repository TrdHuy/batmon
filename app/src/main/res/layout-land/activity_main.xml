<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#262626">

    <TextView
        android:id="@+id/appTitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginTop="50dp"
        android:fontFamily="@font/samsung_sharp_sans_bold"
        android:text="@string/app_title_glimpse"
        android:textColor="#F8F8F8"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/topToolbar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        android:layout_marginEnd="12dp"
        android:background="@android:color/transparent"
        android:minHeight="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:popupTheme="@style/Theme.AppCompat.Light" />

    <View
        android:id="@+id/headerSpacer"
        android:layout_width="0dp"
        android:layout_height="104dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:id="@+id/contentScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fadeScrollbars="false"
        android:fillViewport="true"
        android:paddingBottom="18dp"
        android:scrollbarStyle="outsideOverlay"
        android:scrollbars="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerSpacer">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/contentContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/phoneCardRoot"
                android:layout_width="@dimen/ui_phone_card_width"
                android:layout_height="@dimen/ui_phone_card_height"
                android:background="@drawable/bg_ui_phone_shell"
                android:clipChildren="false"
                android:clipToPadding="false"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/controllerPager"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/ui_status_pager_height"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:overScrollMode="never"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.android.synclab.glimpse.presentation.view.SettingsPanelView
                    android:id="@+id/utilSettingsPanel"
                    android:layout_width="@dimen/ui_settings_panel_width"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ui_util_panel_top_margin"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/controllerPager"
                    app:panelCardBackground="@drawable/bg_ui_settings_card"
                    app:panelCardHeight="@dimen/ui_panel_card_height_util"
                    app:panelTitle="@string/panel_util_category" />

                <com.android.synclab.glimpse.presentation.view.SettingsPanelView
                    android:id="@+id/otherSettingsPanel"
                    android:layout_width="@dimen/ui_settings_panel_width"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ui_other_panel_top_margin"
                    app:layout_constraintEnd_toEndOf="@id/utilSettingsPanel"
                    app:layout_constraintStart_toStartOf="@id/utilSettingsPanel"
                    app:layout_constraintTop_toBottomOf="@id/utilSettingsPanel"
                    app:panelCardBackground="@drawable/bg_ui_limit_card"
                    app:panelCardHeight="@dimen/ui_panel_card_height_other"
                    app:panelTitle="@string/panel_other_category" />

                <View
                    android:id="@+id/phoneCardBottomSpacer"
                    android:layout_width="0dp"
                    android:layout_height="24dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/otherSettingsPanel" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
