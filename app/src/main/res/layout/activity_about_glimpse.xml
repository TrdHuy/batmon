<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#262626">

    <ImageButton
        android:id="@+id/aboutBackButton"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="44dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/about_glimpse_back"
        android:padding="14dp"
        android:src="@drawable/ic_about_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/aboutInfoButton"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginTop="44dp"
        android:layout_marginEnd="24dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/about_glimpse_app_info"
        android:padding="13dp"
        android:src="@drawable/ic_about_info"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/aboutTitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/samsung_sharp_sans_bold"
        android:gravity="center"
        android:text="@string/about_glimpse_title"
        android:textColor="#F8F8F8"
        android:textSize="44sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/aboutSubtitleText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/aboutBackButton"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/aboutSubtitleText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="36dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="36dp"
        android:fontFamily="@font/samsung_sharp_sans"
        android:gravity="center"
        android:lineSpacingExtra="3dp"
        android:text="@string/about_glimpse_subtitle"
        android:textColor="#CFCFD4"
        android:textSize="17sp"
        app:layout_constraintBottom_toTopOf="@id/aboutVersionText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/aboutTitleText" />

    <TextView
        android:id="@+id/aboutVersionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:fontFamily="@font/samsung_sharp_sans"
        android:gravity="center"
        android:textColor="#8F8F96"
        android:textSize="18sp"
        app:layout_constraintBottom_toTopOf="@id/aboutActionsContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/aboutSubtitleText" />

    <LinearLayout
        android:id="@+id/aboutActionsContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="52dp"
        android:layout_marginEnd="52dp"
        android:layout_marginBottom="72dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/reportProblemButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:fontFamily="@font/samsung_sharp_sans_bold"
            android:text="@string/about_glimpse_report_problem"
            android:textAllCaps="false"
            android:textColor="#101014"
            android:textSize="18sp"
            app:backgroundTint="#E1E1E5"
            app:cornerRadius="32dp"
            app:rippleColor="#B7B7BC" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/checkUpdateButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="14dp"
            android:fontFamily="@font/samsung_sharp_sans_bold"
            android:text="@string/about_glimpse_check_for_update"
            android:textAllCaps="false"
            android:textColor="#101014"
            android:textSize="18sp"
            app:backgroundTint="#E1E1E5"
            app:cornerRadius="32dp"
            app:rippleColor="#B7B7BC" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
