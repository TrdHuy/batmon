<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#262626">

    <ImageButton
        android:id="@+id/featureDetailBackButton"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginStart="6dp"
        android:layout_marginTop="44dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/about_glimpse_back"
        android:src="@drawable/ic_about_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:id="@+id/featureDetailScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingBottom="36dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/featureDetailBackButton">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/featureDetailIcon"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginTop="24dp"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/featureDetailTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="@font/samsung_sharp_sans_bold"
                android:textColor="#F8F8F8"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/featureDetailSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/samsung_sharp_sans"
                android:lineSpacingExtra="3dp"
                android:textColor="#CFCFD4"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:fontFamily="@font/samsung_sharp_sans_bold"
                android:text="@string/feature_guide_section_what_it_does"
                android:textColor="#F8F8F8"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/featureDetailWhatItDoesText"
                style="@style/FeatureGuideDetailBodyText" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:fontFamily="@font/samsung_sharp_sans_bold"
                android:text="@string/feature_guide_section_benefits"
                android:textColor="#F8F8F8"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/featureDetailBenefitsText"
                style="@style/FeatureGuideDetailBodyText" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:fontFamily="@font/samsung_sharp_sans_bold"
                android:text="@string/feature_guide_section_how_it_works"
                android:textColor="#F8F8F8"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/featureDetailHowItWorksText"
                style="@style/FeatureGuideDetailBodyText" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:fontFamily="@font/samsung_sharp_sans_bold"
                android:text="@string/feature_guide_section_notes"
                android:textColor="#F8F8F8"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/featureDetailNotesText"
                style="@style/FeatureGuideDetailBodyText" />
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
