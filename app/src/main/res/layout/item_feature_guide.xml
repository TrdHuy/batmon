<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/featureGuideItemRoot"
    android:layout_width="match_parent"
    android:layout_height="88dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="@drawable/ripple_setting_item_white">

    <ImageView
        android:id="@+id/featureGuideItemIcon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="4dp"
        android:contentDescription="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/featureGuideItemTextContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="12dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/featureGuideItemChevron"
        app:layout_constraintStart_toEndOf="@id/featureGuideItemIcon"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/featureGuideItemTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="@font/samsung_sharp_sans_bold"
            android:maxLines="1"
            android:textColor="#F8F8F8"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/featureGuideItemDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:fontFamily="@font/samsung_sharp_sans"
            android:maxLines="2"
            android:textColor="#A9A9B0"
            android:textSize="13sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/featureGuideItemChevron"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_chevron_right"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/featureGuideItemSeparator"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#151515"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/featureGuideItemTextContainer" />

</androidx.constraintlayout.widget.ConstraintLayout>
