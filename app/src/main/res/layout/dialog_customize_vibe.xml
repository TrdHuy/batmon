<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_customize_vibe_panel"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="18dp"
    android:paddingEnd="20dp"
    android:paddingBottom="16dp">

    <TextView
        android:id="@+id/customizeVibeTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/samsung_sharp_sans_bold"
        android:gravity="center"
        android:text="@string/customize_vibe_dialog_title"
        android:textColor="#F5F7FA"
        android:textSize="16sp"
        android:textStyle="bold" />

    <View
        android:id="@+id/colorPreview"
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_customize_vibe_preview_frame" />

    <TextView
        android:id="@+id/colorHexText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:fontFamily="@font/samsung_sharp_sans_medium"
        android:gravity="center"
        android:text="#2C64FF"
        android:textColor="#D9DEE5"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/samsung_sharp_sans_medium"
            android:text="@string/customize_vibe_dialog_red"
            android:textColor="#E0E6ED"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/redValueText"
            android:layout_width="44dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/samsung_sharp_sans_medium"
            android:gravity="end"
            android:text="0"
            android:textColor="#AAB6C3"
            android:textSize="12sp" />
    </LinearLayout>

    <SeekBar
        android:id="@+id/redSeekBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="255"
        android:progressTint="#EF4B4B"
        android:thumbTint="#EF4B4B" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/samsung_sharp_sans_medium"
            android:text="@string/customize_vibe_dialog_green"
            android:textColor="#E0E6ED"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/greenValueText"
            android:layout_width="44dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/samsung_sharp_sans_medium"
            android:gravity="end"
            android:text="0"
            android:textColor="#AAB6C3"
            android:textSize="12sp" />
    </LinearLayout>

    <SeekBar
        android:id="@+id/greenSeekBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="255"
        android:progressTint="#3ECC7A"
        android:thumbTint="#3ECC7A" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/samsung_sharp_sans_medium"
            android:text="@string/customize_vibe_dialog_blue"
            android:textColor="#E0E6ED"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/blueValueText"
            android:layout_width="44dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/samsung_sharp_sans_medium"
            android:gravity="end"
            android:text="0"
            android:textColor="#AAB6C3"
            android:textSize="12sp" />
    </LinearLayout>

    <SeekBar
        android:id="@+id/blueSeekBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="255"
        android:progressTint="#4B7EFF"
        android:thumbTint="#4B7EFF" />

    <Button
        android:id="@+id/closeButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/customize_vibe_dialog_close"
        android:textAllCaps="false" />

</LinearLayout>
