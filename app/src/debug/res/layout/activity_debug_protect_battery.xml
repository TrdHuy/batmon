<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/debugProtectBatteryTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/samsung_sharp_sans"
            android:text="@string/debug_protect_battery_title"
            android:textColor="#111111"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/debugProtectBatteryStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/samsung_sharp_sans"
            android:textColor="#333333"
            android:textSize="18sp" />

        <Button
            android:id="@+id/debugMockControllersEnableButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/debug_mock_controllers_enable" />

        <Button
            android:id="@+id/debugMockControllersDisableButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/debug_mock_controllers_disable" />

        <Button
            android:id="@+id/debugProtectBatterySendAlertButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/debug_protect_battery_send_alert" />
    </LinearLayout>
</ScrollView>
